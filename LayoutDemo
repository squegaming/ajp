import java.awt.*;

public class LayoutDemo {

    public static void main(String[] args) {

        Frame f = new Frame("Layout Demo");

        f.setLayout(new FlowLayout());

        f.add(new Button("Button 1"));
        f.add(new Button("Button 2"));
        f.add(new Button("Button 3"));

        f.setSize(400, 300);
        f.setVisible(true);
    }
}
